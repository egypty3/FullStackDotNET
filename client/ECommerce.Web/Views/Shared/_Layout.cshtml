<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopNow</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Animate.css -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
    <!-- DataTables Bootstrap 5 -->
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet" />
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-shopping-bag me-2"></i>ShopNow
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto"></ul>
                <ul class="navbar-nav">
                    <li class="nav-item auth-required" style="display:none;">
                        <a class="nav-link" href="/Admin/Dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i> Admin Panel
                        </a>
                    </li>
                    <li class="nav-item auth-required" style="display:none;">
                        <span class="nav-link text-light">
                            <i class="fas fa-user-circle me-1"></i> <span id="nav-username"></span>
                        </span>
                    </li>
                    <li class="nav-item auth-required" style="display:none;">
                        <a class="nav-link" href="#" onclick="logout(); return false;">
                            <i class="fas fa-sign-out-alt me-1"></i> Logout
                        </a>
                    </li>
                    <li class="nav-item no-auth">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            <i class="fas fa-sign-in-alt me-1"></i> Login
                        </a>
                    </li>
                    <li class="nav-item no-auth">
                        <a class="nav-link btn btn-outline-light btn-sm ms-2 px-3" asp-controller="Account"
                               asp-action="Register">
                            <i class="fas fa-user-plus me-1"></i> Register
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="text-center py-4 mt-auto">
        <div class="container">
            <div class="row mb-3">
                <div class="col-md-4 text-md-start mb-2 mb-md-0">
                    <h6 class="fw-bold"><i class="fas fa-shopping-bag me-1 text-primary"></i> ShopNow</h6>
                    <small class="text-muted">Your one-stop shop for everything.</small>
                </div>
                <div class="col-md-4 mb-2 mb-md-0">
                    <small class="text-muted">
                        <a href="/" class="text-muted text-decoration-none me-3">Home</a>
                        <a href="/#products" class="text-muted text-decoration-none me-3">Products</a>
                        <a href="/Home/Privacy" class="text-muted text-decoration-none">Privacy</a>
                    </small>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="#" class="text-muted me-2"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-muted me-2"><i class="fab fa-twitter fa-lg"></i></a>
                    <a href="#" class="text-muted me-2"><i class="fab fa-instagram fa-lg"></i></a>
                </div>
            </div>
            <hr class="my-2">
            <p class="mb-0 text-muted small">
                &copy; @DateTime.Now.Year <strong>ShopNow</strong> &mdash; Clean Architecture E-Commerce Platform
            </p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>