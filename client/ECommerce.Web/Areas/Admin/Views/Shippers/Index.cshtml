@{
    ViewData["Title"] = "Shippers";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeIn">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-truck me-2 text-primary"></i>Shippers</h2>
        <p class="text-muted mb-0">Manage shipping carriers</p>
    </div>
    <button class="btn btn-primary" onclick="showCreateShipperModal()">
        <i class="fas fa-plus me-2"></i>Add Shipper
    </button>
</div>

<!-- Shipper Cards -->
<div id="shipper-cards" class="row g-4 mb-4 animate__animated animate__fadeInUp"></div>

<!-- Shipper Table -->
<div class="card shadow-sm animate__animated animate__fadeInUp">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Shipper List</h5>
    </div>
    <div class="card-body">
        <table id="shippersTable" class="table table-hover w-100">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>Contact Person</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Website</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Create/Edit Shipper Modal -->
<div class="modal fade" id="shipperModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="shipperModalTitle">
                    <i class="fas fa-plus me-2"></i>Add Shipper
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="shipperForm">
                    <input type="hidden" id="shipperId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Company Name *</label>
                        <input type="text" class="form-control" id="shipperCompanyName" maxlength="200" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contact Person</label>
                        <input type="text" class="form-control" id="shipperContactPerson" maxlength="200" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Phone *</label>
                            <input type="text" class="form-control" id="shipperPhone" maxlength="20" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" class="form-control" id="shipperEmail" maxlength="200" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Website</label>
                        <input type="url" class="form-control" id="shipperWebsite" placeholder="https://..." />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveShipper()">
                    <i class="fas fa-save me-1"></i>Save Shipper
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var shippersTable;
var allShippers = [];
var shipperIcons = { 'FedEx': 'fa-jet-fighter', 'UPS': 'fa-box', 'DHL Express': 'fa-globe', 'USPS': 'fa-flag-usa' };
var shipperColors = ['danger', 'warning', 'info', 'primary', 'success', 'secondary'];

$(function () { loadShippers(); });

function loadShippers() {
    apiGet('/api/shippers', function (data) {
        allShippers = data;
        renderShipperCards(data);
        initShippersTable(data);
    });
}

function renderShipperCards(data) {
    var html = '';
    data.forEach(function (s, i) {
        var icon = shipperIcons[s.companyName] || 'fa-truck';
        var color = shipperColors[i % shipperColors.length];
        html += '<div class="col-md-4 col-lg-3 animate__animated animate__fadeIn">' +
            '<div class="card h-100 shadow-sm border-0" style="border-left: 4px solid var(--bs-' + color + ') !important;">' +
                '<div class="card-body text-center">' +
                    '<div class="rounded-circle bg-' + color + ' bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:60px;height:60px;">' +
                        '<i class="fas ' + icon + ' fa-xl text-' + color + '"></i>' +
                    '</div>' +
                    '<h6 class="fw-bold mb-1">' + escapeHtml(s.companyName) + '</h6>' +
                    '<p class="text-muted small mb-2">' + escapeHtml(s.contactPerson || 'No contact') + '</p>' +
                    (s.isActive ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Active</span>' : '<span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Inactive</span>') +
                '</div>' +
            '</div></div>';
    });
    $('#shipper-cards').html(html);
}

function initShippersTable(data) {
    if (shippersTable) { shippersTable.clear().rows.add(data).draw(); return; }
    var isAuth = !!localStorage.getItem('jwt_token');
    var columns = [
        { data: 'companyName', render: function (d) { var icon = shipperIcons[d] || 'fa-truck'; return '<i class="fas ' + icon + ' me-2 text-primary"></i><span class="fw-semibold">' + escapeHtml(d) + '</span>'; } },
        { data: 'contactPerson', render: function (d) { return escapeHtml(d || '-'); } },
        { data: 'phone', render: function (d) { return escapeHtml(d); } },
        { data: 'email', render: function (d) { return d ? '<a href="mailto:' + escapeHtml(d) + '">' + escapeHtml(d) + '</a>' : '-'; } },
        { data: 'website', render: function (d) { return d ? '<a href="' + escapeHtml(d) + '" target="_blank" rel="noopener"><i class="fas fa-external-link-alt"></i></a>' : '-'; } },
        { data: 'isActive', render: function (d) { return d ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Active</span>' : '<span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Inactive</span>'; } }
    ];
    if (isAuth) {
        columns.push({ data: null, orderable: false, render: function (d, t, row) {
            return '<div class="btn-group btn-group-sm">' +
                '<button class="btn btn-outline-primary" title="Edit" onclick="editShipper(\'' + row.id + '\')"><i class="fas fa-edit"></i></button>' +
                '<button class="btn btn-outline-danger" title="Delete" onclick="deleteShipper(\'' + row.id + '\')"><i class="fas fa-trash"></i></button></div>';
        }});
    }
    shippersTable = $('#shippersTable').DataTable({ data: data, columns: columns, responsive: true, pageLength: 10,
        language: { emptyTable: '<div class="text-center py-4"><i class="fas fa-truck fa-3x text-muted mb-3"></i><p class="text-muted">No shippers found</p></div>', search: '<i class="fas fa-search"></i>', searchPlaceholder: 'Search shippers...' },
        dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>rtip'
    });
}

function showCreateShipperModal() {
    $('#shipperModalTitle').html('<i class="fas fa-plus me-2"></i>Add Shipper');
    $('#shipperForm')[0].reset();
    $('#shipperId').val('');
    new bootstrap.Modal('#shipperModal').show();
}

function editShipper(id) {
    var s = allShippers.find(function (x) { return x.id === id; });
    if (!s) return;
    $('#shipperModalTitle').html('<i class="fas fa-edit me-2"></i>Edit Shipper');
    $('#shipperId').val(s.id);
    $('#shipperCompanyName').val(s.companyName);
    $('#shipperContactPerson').val(s.contactPerson);
    $('#shipperPhone').val(s.phone);
    $('#shipperEmail').val(s.email);
    $('#shipperWebsite').val(s.website);
    new bootstrap.Modal('#shipperModal').show();
}

function saveShipper() {
    var id = $('#shipperId').val();
    var payload = {
        companyName: $('#shipperCompanyName').val(),
        contactPerson: $('#shipperContactPerson').val(),
        phone: $('#shipperPhone').val(),
        email: $('#shipperEmail').val(),
        website: $('#shipperWebsite').val()
    };
    if (!payload.companyName || !payload.phone) { return toastError('Company name and phone are required.'); }
    if (id) {
        payload.id = id;
        apiRequest('PUT', '/api/shippers/' + id, payload, function () {
            bootstrap.Modal.getInstance(document.getElementById('shipperModal')).hide();
            toastSuccess('Shipper updated successfully!');
            loadShippers();
        });
    } else {
        apiRequest('POST', '/api/shippers', payload, function () {
            bootstrap.Modal.getInstance(document.getElementById('shipperModal')).hide();
            toastSuccess('Shipper created successfully!');
            loadShippers();
        });
    }
}

function deleteShipper(id) {
    Swal.fire({ title: 'Delete Shipper?', text: 'This action will deactivate the shipper.', icon: 'warning', showCancelButton: true,
        confirmButtonColor: '#dc3545', confirmButtonText: '<i class="fas fa-trash me-1"></i>Yes, delete!', cancelButtonText: 'Cancel'
    }).then(function (result) {
        if (result.isConfirmed) {
            apiRequest('DELETE', '/api/shippers/' + id, null, function () {
                toastSuccess('Shipper deleted successfully!');
                loadShippers();
            });
        }
    });
}
</script>
}
