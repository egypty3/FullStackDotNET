<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopNow Admin</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Animate.css -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
    <!-- DataTables Bootstrap 5 -->
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet" />
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/admin.css" rel="stylesheet" />
</head>
<body class="admin-body">
    <!-- Admin Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <a href="/Admin/Dashboard">
                <i class="fas fa-shopping-bag me-2"></i>
                <span class="brand-text">ShopNow</span>
            </a>
            <span class="badge bg-primary ms-2 badge-sm">Admin</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-title">Main</div>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="sidebar-link"
                   data-page="dashboard">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>

            <div class="nav-section-title">Catalog</div>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="sidebar-link" data-page="products">
                <i class="fas fa-box"></i>
                <span>Products</span>
            </a>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="sidebar-link"
                   data-page="categories">
                <i class="fas fa-tags"></i>
                <span>Categories</span>
            </a>

            <div class="nav-section-title">Sales</div>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="sidebar-link" data-page="orders">
                <i class="fas fa-shopping-cart"></i>
                <span>Orders</span>
            </a>
            <a asp-area="Admin" asp-controller="Customers" asp-action="Index" class="sidebar-link"
                   data-page="customers">
                <i class="fas fa-users"></i>
                <span>Customers</span>
            </a>
            <a asp-area="Admin" asp-controller="Coupons" asp-action="Index" class="sidebar-link" data-page="coupons">
                <i class="fas fa-ticket-alt"></i>
                <span>Coupons</span>
            </a>

            <div class="nav-section-title">Fulfillment</div>
            <a asp-area="Admin" asp-controller="Shippers" asp-action="Index" class="sidebar-link" data-page="shippers">
                <i class="fas fa-building"></i>
                <span>Shippers</span>
            </a>
            <a asp-area="Admin" asp-controller="Shipments" asp-action="Index" class="sidebar-link"
                   data-page="shipments">
                <i class="fas fa-shipping-fast"></i>
                <span>Shipments</span>
            </a>
            <a asp-area="Admin" asp-controller="Payments" asp-action="Index" class="sidebar-link" data-page="payments">
                <i class="fas fa-credit-card"></i>
                <span>Payments</span>
            </a>

            <div class="nav-section-title">Engagement</div>
            <a asp-area="Admin" asp-controller="Employees" asp-action="Index" class="sidebar-link"
                   data-page="employees">
                <i class="fas fa-user-tie"></i>
                <span>Employees</span>
            </a>
            <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="sidebar-link" data-page="reviews">
                <i class="fas fa-star"></i>
                <span>Reviews</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/" class="sidebar-link">
                <i class="fas fa-store"></i>
                <span>View Store</span>
            </a>
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div class="admin-main">
        <!-- Top Bar -->
        <header class="admin-topbar">
            <div class="d-flex align-items-center">
                <button class="btn btn-link text-dark sidebar-toggle me-3 d-lg-none" onclick="toggleSidebar()">
                    <i class="fas fa-bars fa-lg"></i>
                </button>
                <h5 class="mb-0 fw-semibold topbar-title">@ViewData["Title"]</h5>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted d-none d-md-inline">
                    <i class="fas fa-user-circle me-1"></i>
                    <span id="nav-username">Admin</span>
                </span>
                <a href="#" onclick="logout(); return false;" class="btn btn-outline-danger btn-sm">
                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                </a>
            </div>
        </header>

        <!-- Content -->
        <main class="admin-content">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="admin-footer">
            <p class="mb-0 text-muted">
                <i class="fas fa-code me-1"></i> &copy; @DateTime.Now.Year <strong>ShopNow</strong> &mdash; Admin Panel
            </p>
        </footer>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js"></script>
    <script>
        // Sidebar toggle
        function toggleSidebar() {
        document.getElementById('adminSidebar').classList.toggle('show');
        document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        // Active sidebar link
        $(function () {
        var path = window.location.pathname.toLowerCase();
        $('.sidebar-link').each(function () {
        var href = $(this).attr('href');
        if (href && path === href.toLowerCase()) {
        $(this).addClass('active');
        } else if (path === '/admin' && $(this).data('page') === 'dashboard') {
        $(this).addClass('active');
        } else if (path === '/admin/dashboard' && $(this).data('page') === 'dashboard') {
        $(this).addClass('active');
        }
        });

        // Admin auth check
        var token = localStorage.getItem('jwt_token');
        if (!token) {
        window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
        }
        var name = localStorage.getItem('user_name') || localStorage.getItem('user_email') || 'Admin';
        $('#nav-username').text(name);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>