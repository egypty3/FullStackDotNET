@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeIn">
    <div>
        <h2 class="fw-bold mb-1"><i class="fas fa-box me-2 text-primary"></i>Products</h2>
        <p class="text-muted mb-0">Manage your product catalog</p>
    </div>
    <button class="btn btn-primary" onclick="showCreateProductModal()">
        <i class="fas fa-plus me-2"></i>Add Product
    </button>
</div>

<!-- Product Cards (Grid View) -->
<div id="products-grid" class="row g-4 animate__animated animate__fadeInUp" style="display:none;"></div>

<!-- Product Table (Table View) -->
<div class="card shadow-sm animate__animated animate__fadeInUp">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-table me-2"></i>Product List</h5>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-primary active" onclick="showView('table')" id="btn-table-view">
                <i class="fas fa-list"></i>
            </button>
            <button class="btn btn-outline-primary" onclick="showView('grid')" id="btn-grid-view">
                <i class="fas fa-th"></i>
            </button>
        </div>
    </div>
    <div class="card-body" id="table-view">
        <table id="productsTable" class="table table-hover w-100">
            <thead>
                <tr>                    <th style="width:60px;">Image</th>                    <th>Name</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Create/Edit Product Modal -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="productModalTitle">
                    <i class="fas fa-plus me-2"></i>Add Product
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="productForm">
                    <input type="hidden" id="productId" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Product Name</label>
                            <input type="text" class="form-control" id="productName" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">SKU</label>
                            <input type="text" class="form-control" id="productSku" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" id="productDescription" rows="3"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Price</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                                <input type="number" class="form-control" id="productPrice" step="0.01" min="0" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Stock Quantity</label>
                            <input type="number" class="form-control" id="productStock" min="0" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select" id="productCategory" required>
                                <option value="">Select Category</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold"><i class="fas fa-image me-1"></i>Image URL</label>
                            <input type="url" class="form-control" id="productImageUrl" placeholder="https://example.com/image.jpg" />
                            <div id="imagePreviewContainer" class="mt-2" style="display:none;">
                                <img id="imagePreview" src="" alt="Preview" class="rounded border" style="max-height:120px; max-width:100%; object-fit:cover;" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveProduct()">
                    <i class="fas fa-save me-1"></i>Save Product
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Order Modal -->
<div class="modal fade" id="orderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-shopping-cart me-2"></i>Place Order</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">You are ordering: <strong id="order-product-name"></strong></p>
                <input type="hidden" id="order-product-id" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Quantity</label>
                    <input type="number" class="form-control" id="order-quantity" min="1" value="1" />
                </div>
                <h6 class="fw-bold">Shipping Address</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <input type="text" class="form-control" id="order-street" placeholder="Street" required />
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="order-city" placeholder="City" required />
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control" id="order-state" placeholder="State" required />
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control" id="order-zip" placeholder="Zip" required />
                    </div>
                    <div class="col-12">
                        <input type="text" class="form-control" id="order-country" placeholder="Country" value="US" required />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="placeOrder()">
                    <i class="fas fa-check me-1"></i>Place Order
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var productsTable;
var allProducts = [];
var allCategories = [];

$(function () {
    loadCategories(function () {
        loadProducts();
    });

    $('#productImageUrl').on('input', function () {
        previewImage($(this).val());
    });
});

function loadCategories(callback) {
    apiGet('/api/categories', function (data) {
        allCategories = data;
        var sel = $('#productCategory');
        sel.find('option:not(:first)').remove();
        data.forEach(function (c) {
            if (c.isActive) {
                sel.append('<option value="' + c.id + '">' + escapeHtml(c.name) + '</option>');
            }
        });
        if (callback) callback();
    });
}

function getCategoryName(categoryId) {
    var cat = allCategories.find(function (c) { return c.id === categoryId; });
    return cat ? cat.name : 'Unknown';
}

function loadProducts() {
    apiGet('/api/products', function (data) {
        allProducts = data;
        initTable(data);
        renderGrid(data);
    });
}

function initTable(data) {
    if (productsTable) {
        productsTable.clear().rows.add(data).draw();
        return;
    }

    var isAuth = !!localStorage.getItem('jwt_token');

    var columns = [
        {
            data: 'imageUrl',
            orderable: false,
            render: function (d) {
                if (d) {
                    return '<img src="' + escapeHtml(d) + '" alt="Product" class="rounded" style="width:45px;height:45px;object-fit:cover;" onerror="this.outerHTML=\'<i class=fas fa-box fa-2x text-muted></i>\'" />';
                }
                return '<i class="fas fa-box fa-2x text-muted" style="opacity:0.3;"></i>';
            }
        },
        {
            data: 'name',
            render: function (d, t, row) {
                return '<div class="fw-semibold">' + escapeHtml(d) + '</div>' +
                       '<small class="text-muted">' + escapeHtml(row.description || '').substring(0, 60) + '</small>';
            }
        },
        { data: 'sku', render: function(d) { return '<code>' + escapeHtml(d) + '</code>'; } },
        { data: 'categoryName', render: function(d) {
            return '<span class="badge bg-primary">' + escapeHtml(d || 'Unknown') + '</span>';
        }},
        { data: 'price', render: function(d) { return '<span class="fw-bold text-success">$' + d.toFixed(2) + '</span>'; } },
        { data: 'stockQuantity', render: function(d) {
            var cls = d > 10 ? 'success' : d > 0 ? 'warning' : 'danger';
            return '<span class="badge bg-' + cls + '">' + d + '</span>';
        }},
        { data: 'isActive', render: function(d) {
            return d ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Active</span>'
                     : '<span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Inactive</span>';
        }}
    ];

    if (isAuth) {
        columns.push({
            data: null,
            orderable: false,
            render: function(d, t, row) {
                return '<div class="btn-group btn-group-sm">' +
                    '<button class="btn btn-outline-success" title="Order" onclick="showOrderModal(\'' + row.id + '\')"><i class="fas fa-shopping-cart"></i></button>' +
                    '<button class="btn btn-outline-primary" title="Edit" onclick="editProduct(\'' + row.id + '\')"><i class="fas fa-edit"></i></button>' +
                    '<button class="btn btn-outline-danger" title="Delete" onclick="deleteProduct(\'' + row.id + '\')"><i class="fas fa-trash"></i></button>' +
                    '</div>';
            }
        });
    }

    productsTable = $('#productsTable').DataTable({
        data: data,
        columns: columns,
        responsive: true,
        pageLength: 10,
        language: {
            emptyTable: '<div class="text-center py-4"><i class="fas fa-box-open fa-3x text-muted mb-3"></i><p class="text-muted">No products found</p></div>',
            search: '<i class="fas fa-search"></i>',
            searchPlaceholder: 'Search products...'
        },
        dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>rtip'
    });
}

function renderGrid(data) {
    var html = '';
    data.forEach(function (p) {
        var stockClass = p.stockQuantity > 10 ? 'success' : p.stockQuantity > 0 ? 'warning' : 'danger';
        var catName = p.categoryName || getCategoryName(p.categoryId);
        var imgHtml = p.imageUrl
            ? '<img src="' + escapeHtml(p.imageUrl) + '" alt="' + escapeHtml(p.name) + '" class="w-100" style="height:180px;object-fit:cover;" onerror="this.outerHTML=\'<div class=d-flex align-items-center justify-content-center style=height:180px;background:#f8f9fa><i class=fas fa-box fa-4x text-muted style=opacity:0.2></i></div>\'" />'
            : '<div class="d-flex align-items-center justify-content-center" style="height:180px;background:linear-gradient(135deg,#f8f9fa,#e9ecef);"><i class="fas fa-box fa-4x text-muted" style="opacity:0.2;"></i></div>';
        html += '<div class="col-md-4 col-lg-3 animate__animated animate__fadeIn">' +
            '<div class="card product-card h-100 shadow-sm overflow-hidden">' +
                imgHtml +
                '<div class="card-body">' +
                    '<div class="d-flex justify-content-between align-items-start mb-2">' +
                        '<span class="badge bg-primary">' + escapeHtml(catName) + '</span>' +
                        (p.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Inactive</span>') +
                    '</div>' +
                    '<h6 class="fw-bold mt-2">' + escapeHtml(p.name) + '</h6>' +
                    '<p class="text-muted small mb-2">' + escapeHtml(p.description || '').substring(0, 80) + '</p>' +
                    '<div class="d-flex justify-content-between align-items-center">' +
                        '<span class="fs-5 fw-bold text-success">$' + p.price.toFixed(2) + '</span>' +
                        '<span class="badge bg-' + stockClass + '">' + p.stockQuantity + ' in stock</span>' +
                    '</div>' +
                '</div>' +
                '<div class="card-footer bg-white border-top-0">' +
                    '<div class="btn-group w-100 btn-group-sm">' +
                        '<button class="btn btn-success" onclick="showOrderModal(\'' + p.id + '\')"><i class="fas fa-cart-plus me-1"></i>Order</button>' +
                        '<button class="btn btn-outline-primary" onclick="editProduct(\'' + p.id + '\')"><i class="fas fa-edit"></i></button>' +
                        '<button class="btn btn-outline-danger" onclick="deleteProduct(\'' + p.id + '\')"><i class="fas fa-trash"></i></button>' +
                    '</div>' +
                '</div>' +
            '</div>' +
        '</div>';
    });
    $('#products-grid').html(html);
    updateAuthUI();
}

function showView(view) {
    if (view === 'grid') {
        $('#table-view').closest('.card').hide();
        $('#products-grid').show();
        $('#btn-grid-view').addClass('active');
        $('#btn-table-view').removeClass('active');
    } else {
        $('#products-grid').hide();
        $('#table-view').closest('.card').show();
        $('#btn-table-view').addClass('active');
        $('#btn-grid-view').removeClass('active');
    }
}

function showCreateProductModal() {
    $('#productModalTitle').html('<i class="fas fa-plus me-2"></i>Add Product');
    $('#productForm')[0].reset();
    $('#productId').val('');
    $('#imagePreviewContainer').hide();
    new bootstrap.Modal('#productModal').show();
}

function previewImage(url) {
    if (url) {
        $('#imagePreview').attr('src', url);
        $('#imagePreviewContainer').show();
    } else {
        $('#imagePreviewContainer').hide();
    }
}

function editProduct(id) {
    var p = allProducts.find(function(x) { return x.id === id; });
    if (!p) return;
    $('#productModalTitle').html('<i class="fas fa-edit me-2"></i>Edit Product');
    $('#productId').val(p.id);
    $('#productName').val(p.name);
    $('#productSku').val(p.sku);
    $('#productDescription').val(p.description);
    $('#productPrice').val(p.price);
    $('#productStock').val(p.stockQuantity);
    $('#productCategory').val(p.categoryId);
    $('#productImageUrl').val(p.imageUrl || '');
    previewImage(p.imageUrl);
    new bootstrap.Modal('#productModal').show();
}

function saveProduct() {
    var id = $('#productId').val();
    var payload = {
        name: $('#productName').val(),
        sku: $('#productSku').val(),
        description: $('#productDescription').val(),
        price: parseFloat($('#productPrice').val()),
        stockQuantity: parseInt($('#productStock').val()),
        categoryId: $('#productCategory').val(),
        imageUrl: $('#productImageUrl').val() || null
    };

    if (!payload.name || !payload.sku || !payload.price || !payload.categoryId) {
        return toastError('Please fill in all required fields.');
    }

    if (id) {
        payload.id = id;
    }

    var url = id ? '/api/products/' + id : '/api/products';
    var method = id ? 'PUT' : 'POST';

    apiRequest(method, url, payload, function () {
        bootstrap.Modal.getInstance(document.getElementById('productModal')).hide();
        toastSuccess(id ? 'Product updated successfully!' : 'Product created successfully!');
        loadProducts();
    });
}

function deleteProduct(id) {
    Swal.fire({
        title: 'Delete Product?',
        text: 'This action will deactivate the product.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        confirmButtonText: '<i class="fas fa-trash me-1"></i>Yes, delete it!',
        cancelButtonText: 'Cancel'
    }).then(function (result) {
        if (result.isConfirmed) {
            apiRequest('DELETE', '/api/products/' + id, null, function () {
                toastSuccess('Product deleted successfully!');
                loadProducts();
            });
        }
    });
}

function showOrderModal(productId) {
    var p = allProducts.find(function(x) { return x.id === productId; });
    if (!p) return;
    $('#order-product-name').text(p.name);
    $('#order-product-id').val(productId);
    $('#order-quantity').val(1).attr('max', p.stockQuantity);
    new bootstrap.Modal('#orderModal').show();
}

function placeOrder() {
    var payload = {
        items: [{
            productId: $('#order-product-id').val(),
            quantity: parseInt($('#order-quantity').val())
        }],
        shippingStreet: $('#order-street').val(),
        shippingCity: $('#order-city').val(),
        shippingState: $('#order-state').val(),
        shippingZipCode: $('#order-zip').val(),
        shippingCountry: $('#order-country').val()
    };

    if (!payload.shippingStreet || !payload.shippingCity || !payload.shippingState || !payload.shippingZipCode) {
        return toastError('Please fill in the shipping address.');
    }

    apiRequest('POST', '/api/orders', payload, function () {
        bootstrap.Modal.getInstance(document.getElementById('orderModal')).hide();
        Swal.fire({
            title: 'Order Placed!',
            text: 'Your order has been created successfully.',
            icon: 'success',
            confirmButtonText: 'View My Orders',
            showCancelButton: true,
            cancelButtonText: 'Continue Shopping'
        }).then(function (r) {
            if (r.isConfirmed) window.location.href = '/Admin/Orders';
        });
        loadProducts();
    });
}
</script>
}
